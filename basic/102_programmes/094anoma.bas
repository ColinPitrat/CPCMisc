10 REM ANOMALIE 
20 INK 1,1:INK 2,1:INK 3,1:RANDOMIZE(TIME) 
30 FOR I=1 TO 5:PO$=PO$+CHR$(144)+" ":NEXT I 
40 T=5:DIM B(5,5):CLS 
50 FOR I=1 TO 5
60 LOCATE 2*I+1,1:PRINT I:LOCATE 1,2*I+1:PRINT I 
70 LOCATE 2*I+19,1:PRINT I:LOCATE 19,2*I+1:PRINT I 
75 LOCATE 4,2*I+1:PRINT PO$:LOCATE 22,2*I+1:PRINT PO$ 
80 NEXT I 
100 FOR I=1 TO 22 
110 D=INT(26*RND+1) 
120 L=0:S=T
130 GOSUB 1000 
140 L=18 
150 GOSUB 1000 
160 NEXT I 
170 S=0 
180 GOSUB 1000:INK 1,24:INK 2,6:INK 3,9 
190 PEN 1:LOCATE 1,16: INPUT "LIGNE.......";I
200 PRINT:INPUT "COLONNE ....";T 
210 LOCATE 1,20:IF B(T,I)=D THEN PRINT "BRAVO!...." ELSE PRINT "PERDU!....":WHILE TE<200: SOUND 1,TE,1:TE=TE+1:WEND 
220 PRINT:PRINT "LA LETTRE A TROUVER ETAIT ";CHR$(64+D):END 
1000 U=3+2*INT(RND*T):V=4+L+2*INT(RND*S)
1010 C=TEST((V-1)*16+8,(25-U)*16+8)
1020 IF C<>1 AND S<>0 THEN 1000 
1030 IF S=0 THEN IF B((V-20)/2,(U-1)/2)=D THEN 1000 
1040 IF L<>0 THEN B((V-20)/2,(U-1)/2)=D 
1050 LOCATE V,U:PEN 2-(L<>0):PRINT CHR$(D+64)
1060 RETURN 
